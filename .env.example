# ─────────────────────────────────────────────────────────────
# BD Go — Environment Variables
# Copy this file to .env and fill in ALL required values before
# starting the server with DATABASE_URL configured (production).
#
# Required  = app will refuse to start if missing
# Mandatory = app starts but core feature is broken without it
# Optional  = sensible default exists
# ─────────────────────────────────────────────────────────────

# ── Database [REQUIRED] ──────────────────────────────────────
# PostgreSQL connection string for auth / sessions / reports / credits
DATABASE_URL=postgresql://user:password@localhost:5432/bdgo

# ── JWT Signing Key [REQUIRED] ───────────────────────────────
# Secret used to sign user session tokens.
# MUST be set when DATABASE_URL is configured — app refuses to start otherwise.
# Generate with:
#   python3 -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET=

# ── LLM (MiniMax) [MANDATORY] ────────────────────────────────
# MiniMax API key — all AI features are disabled without this
MINIMAX_API_KEY=

# Optional — Override MiniMax endpoint and model
# MINIMAX_URL=https://api.minimaxi.com/anthropic/v1/messages
# MINIMAX_MODEL=MiniMax-M1-80k

# ── Google OAuth [optional] ──────────────────────────────────
# If not set, Google Sign-In button is disabled entirely.
# Get from: https://console.cloud.google.com/ → APIs & Services → Credentials
# GOOGLE_CLIENT_ID=your-google-oauth-client-id.apps.googleusercontent.com

# ── Internal Email Domains [optional] ────────────────────────
# Users registering with these domains get is_internal=true automatically.
# Comma-separated. Default: yafocapital.com
# INTERNAL_EMAIL_DOMAINS=yafocapital.com,yourcompany.com

# ── CRM Database Paths [optional] ────────────────────────────
# CRM_DB_PATH=~/.openclaw/workspace/crm-database/crm.db
# GUIDELINES_DB_PATH=~/.openclaw/workspace/guidelines/guidelines.db
# CRM_BACKEND=sqlite           # or: postgresql
# CRM_PG_DSN=dbname=bdgo       # used when CRM_BACKEND=postgresql

# ── File Directories [optional] ──────────────────────────────
# BP_DIR=~/.openclaw/workspace/BP
# REPORTS_DIR=~/.openclaw/workspace/Reports

# ── CORS [MANDATORY in production] ──────────────────────────
# Comma-separated list of allowed origins.
# Default (dev only): http://localhost:3000
# Production example — must include Vercel domain + custom domain:
# CORS_ORIGINS=https://bdgo.tech,https://www.bdgo.tech,https://bdgo-iota.vercel.app,http://localhost:3000
CORS_ORIGINS=

# ── Admin Secret [MANDATORY] ─────────────────────────────────
# Protects the /api/admin/* curl/script endpoints (invite codes, user mgmt).
# Generate with:
#   python3 -c "import secrets; print(secrets.token_hex(32))"
# The frontend admin dashboard uses JWT (is_admin flag) instead.
ADMIN_SECRET=

# ── Log Format [optional] ────────────────────────────────────
# Set to "json" for structured log output (recommended in production —
# makes logs searchable in journald / log aggregators).
# Default: human-readable text
# LOG_FORMAT=json

# ── Web Search [optional] ────────────────────────────────────
# TAVILY_API_KEY=tvly-xxxxxxxxxxxx

# ── AIDD 立项中心 SSO [optional] ──────────────────────────────
# Shared secret for HMAC-SHA256 SSO URL signing.
# Must match SSO_SHARED_SECRET in the AIDD backend .env exactly.
# Generate: python3 -c "import secrets; print(secrets.token_hex(32))"
# AIDD_SSO_SECRET=<ask AIDD admin for the shared secret>
# AIDD_BASE_URL=https://aidd-two.vercel.app
